# Letting Partners database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/letting_partners?schema=public"
DIRECT_URL=""

# App/auth
APP_URL="http://localhost:3002"
AUTH_SESSION_SECRET="replace-with-at-least-32-characters"
AUTH_COOKIE_NAME="letting_partners_session"
AUTH_SESSION_TTL_HOURS="12"
ALLOW_ADMIN_PASSIVE_REVERT="false"

# Portal OTP/email delivery
EMAIL_PROVIDER="console"
OTP_EMAIL_FROM="no-reply@lettingpartners.co.uk"
OTP_TTL_MINUTES="10"
OTP_MAX_SENDS_PER_WINDOW="5"
OTP_SEND_WINDOW_MINUTES="10"
OTP_MAX_VERIFY_ATTEMPTS_PER_CODE="5"
OTP_MAX_VERIFY_ATTEMPTS_PER_WINDOW="10"
OTP_VERIFY_WINDOW_MINUTES="10"

# Admin seed user
ADMIN_EMAIL="admin@lettingpartners.co.uk"
ADMIN_PASSWORD="replace-with-a-secure-password"

# Public website form email delivery
RESEND_API_KEY="re_xxxxxxxxxxxx"
FROM_EMAIL="Letting Partners <info@lettingpartners.co.uk>"
NOREPLY_EMAIL="Letting Partners <no-reply@lettingpartners.co.uk>"
MAIL_TO="info@lettingpartners.co.uk"
CONTACT_FORM_TO="info@lettingpartners.co.uk"
TENANT_REGISTRATION_TO="info@lettingpartners.co.uk"

# SMTP placeholders, only required if EMAIL_PROVIDER=smtp
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""

# Website API placeholders, if an external consumer needs them later
WEBSITE_API_KEY=""
WEBSITE_API_BASE_URL="http://localhost:3002/api/website"
